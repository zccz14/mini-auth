{
  "name": "auth-mini",
  "version": "0.1.1",
  "description": "Minimal, opinionated auth server for apps that just need auth.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zccz14/auth-mini.git"
  },
  "homepage": "https://github.com/zccz14/auth-mini#readme",
  "bugs": {
    "url": "https://github.com/zccz14/auth-mini/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "auth-mini": "dist/index.js"
  },
  "oclif": {
    "bin": "auth-mini",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node dist/sdk/build-singleton-iife.js",
    "test": "vitest run tests",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@oclif/core": "^4.8.0",
    "@simplewebauthn/server": "^13.0.0",
    "better-sqlite3": "^12.4.1",
    "cbor-x": "^1.6.4",
    "hono": "^4.10.2",
    "nodemailer": "^8.0.4",
    "oclif": "^4.22.0",
    "pino": "^10.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.1",
    "@types/nodemailer": "^7.0.11",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.5",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.0.0"
  }
}
